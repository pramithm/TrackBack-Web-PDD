{
  "name": "web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://pramithm.github.io/TrackBack-Web-PDD",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test:e2e": "mocha selenium-tests/tests/*.test.js --timeout 90000 --reporter spec",
    "test:e2e:ci": "mocha selenium-tests/tests/*.test.js --timeout 90000 --reporter json --reporter-option output=\"Test Results/mocha-results.json\"",
    "test:login": "mocha selenium-tests/tests/login.test.js --timeout 90000",
    "generate:report": "node selenium-tests/scripts/generate-reports.cjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "mocha": "^11.7.6",
    "exceljs": "^4.4.0",
    "selenium-webdriver": "^4.45.0",
    "vite": "^8.0.12"
  }
}
